PORT=3001

# ── GitHub (optional but recommended for higher rate limits) ──────────────────
# Get a free token at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ── AI Provider (choose one) ──────────────────────────────────────────────────

# OPTION 1: Groq — FREE, no credit card, fast cloud inference
# Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_xxxxxxxxxxxx
# Optional: change the model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama3-8b-8192

# OPTION 2: Ollama — FREE, fully local, no internet needed for AI
# Install from https://ollama.com, then run: ollama pull llama3.2
# Set this to switch to Ollama:
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
